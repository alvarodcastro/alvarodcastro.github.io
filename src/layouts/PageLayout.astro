---
import BaseLayout from './BaseLayout.astro';
import PageHeader from '@/components/ui/PageHeader.astro';
import Container from '@/components/ui/Container.astro';

interface Props {
  title: string;
  description?: string;
  pageTitle?: string;
  pageSubtitle?: string;
  ogImage?: string;
}

const { title, description, pageTitle, pageSubtitle, ogImage } = Astro.props;
---

<BaseLayout title={title} description={description} ogImage={ogImage}>
  <Container>
    {(pageTitle ?? pageSubtitle) && (
      <PageHeader title={pageTitle ?? title} subtitle={pageSubtitle} />
    )}
    <slot />
  </Container>
</BaseLayout>
