---
interface Props {
  href: string;
  label?: string;
  class?: string;
  ariaLabel?: string;
}

const { href, label, class: className = '', ariaLabel } = Astro.props;
---

<a
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  aria-label={ariaLabel}
  class={`inline-flex items-center gap-1 text-[#1E3A8A] hover:underline transition-colors ${className}`}
>
  <slot>{label}</slot>
  <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 opacity-60" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
  </svg>
</a>
