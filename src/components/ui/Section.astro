---
interface Props {
  title?: string;
  subtitle?: string;
  id?: string;
  class?: string;
}

const { title, subtitle, id, class: className = '' } = Astro.props;
---

<section id={id} class={`py-16 ${className}`} aria-labelledby={title ? `${id}-heading` : undefined}>
  {title && (
    <div class="mb-10">
      <h2
        id={id ? `${id}-heading` : undefined}
        class="font-serif text-2xl font-semibold text-[#111827]"
      >
        {title}
      </h2>
      {subtitle && <p class="mt-2 text-[#6B7280] text-sm">{subtitle}</p>}
    </div>
  )}
  <slot />
</section>
