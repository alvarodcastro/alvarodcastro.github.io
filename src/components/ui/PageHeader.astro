---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<div class="pt-16 pb-10 border-b border-[#E5E7EB]">
  <h1 class="font-serif text-3xl sm:text-4xl font-semibold text-[#111827]">{title}</h1>
  {subtitle && <p class="mt-3 text-lg text-[#4B5563] max-w-2xl leading-relaxed">{subtitle}</p>}
</div>
