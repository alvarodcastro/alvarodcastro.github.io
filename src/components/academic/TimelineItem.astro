---
interface Props {
  period: string;
  title: string;
  subtitle?: string;
  description?: string;
  last?: boolean;
}

const { period, title, subtitle, description, last = false } = Astro.props;
---

<div class={`relative flex gap-6 ${last ? '' : 'pb-8'}`}>
  <!-- Timeline line and dot -->
  <div class="flex flex-col items-center">
    <div class="w-2 h-2 rounded-full bg-[#1E3A8A] mt-1.5 shrink-0"></div>
    {!last && <div class="w-px flex-1 bg-[#E5E7EB] mt-2"></div>}
  </div>
  <div class="pb-1">
    <p class="text-xs font-medium text-[#6B7280] mb-0.5">{period}</p>
    <h3 class="font-semibold text-[#111827] text-sm">{title}</h3>
    {subtitle && <p class="text-sm text-[#4B5563]">{subtitle}</p>}
    {description && <p class="text-sm text-[#6B7280] mt-1 leading-relaxed">{description}</p>}
  </div>
</div>
