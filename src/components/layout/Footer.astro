---
import { profile } from '@/data/profile';
import { socialLinks } from '@/data/social';

const year = new Date().getFullYear();
---

<footer class="border-t border-[#E5E7EB] mt-24">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-10">
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-6">
      <div>
        <p class="font-medium text-[#111827] text-sm">{profile.name}</p>
        <p class="text-sm text-[#6B7280] mt-0.5">{profile.title}</p>
        <p class="text-sm text-[#6B7280]">{profile.institution}</p>
      </div>
      <nav aria-label="Social links" class="flex items-center gap-4 flex-wrap">
        {socialLinks.map((link) => (
          <a
            href={link.href}
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm text-[#6B7280] hover:text-[#1E3A8A] transition-colors"
            aria-label={link.label}
          >
            {link.label}
          </a>
        ))}
      </nav>
    </div>
    <div class="mt-8 pt-6 border-t border-[#E5E7EB] flex flex-col sm:flex-row justify-between gap-2 text-xs text-[#9CA3AF]">
      <span>© {year} {profile.name}. All rights reserved.</span>
      <span>Built with <a href="https://astro.build" target="_blank" rel="noopener noreferrer" class="hover:text-[#1E3A8A] transition-colors">Astro</a></span>
    </div>
  </div>
</footer>
