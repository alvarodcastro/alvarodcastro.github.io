---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
---

<BaseLayout title="Page Not Found" noIndex>
  <Container>
    <div class="py-32 text-center max-w-lg mx-auto">
      <p class="text-sm font-semibold text-[#6B7280] uppercase tracking-widest mb-4">404</p>
      <h1 class="font-serif text-3xl font-semibold text-[#111827] mb-4">Page Not Found</h1>
      <p class="text-[#4B5563] mb-8">
        The page you are looking for does not exist or has been moved.
      </p>
      <a href="/" class="btn-primary">Back to Home</a>
    </div>
  </Container>
</BaseLayout>
