---
import PageLayout from '@/layouts/PageLayout.astro';
import { getCollection } from 'astro:content';
import { formatDate } from '@/utils/dates';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const sorted = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<PageLayout
  title="Blog"
  description="Technical notes, research reflections, cybersecurity tutorials, and conference summaries."
  pageTitle="Notes & Blog"
  pageSubtitle="Technical notes, research reflections, conference summaries, and cybersecurity writing."
>
  <div class="py-8">
    {sorted.length > 0
      ? (
        <div class="divide-y divide-[#E5E7EB]">
          {sorted.map((post) => (
            <article class="py-6">
              <div class="flex flex-wrap items-center gap-3 mb-2">
                <time
                  datetime={post.data.date.toISOString()}
                  class="text-sm text-[#6B7280]"
                >
                  {formatDate(post.data.date, { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
                {post.data.tags.slice(0, 3).map((tag) => (
                  <span class="px-1.5 py-0.5 text-xs bg-gray-100 text-gray-500 rounded">
                    {tag}
                  </span>
                ))}
              </div>
              <a
                href={`/blog/${post.slug}`}
                class="group"
              >
                <h2 class="font-semibold text-[#111827] text-lg group-hover:text-[#1E3A8A] transition-colors mb-1">
                  {post.data.title}
                </h2>
              </a>
              <p class="text-sm text-[#4B5563] leading-relaxed">{post.data.description}</p>
              <a
                href={`/blog/${post.slug}`}
                class="text-sm text-[#1E3A8A] hover:underline font-medium mt-2 inline-block"
              >
                Read more →
              </a>
            </article>
          ))}
        </div>
      )
      : (
        <p class="text-[#6B7280] py-12 text-center">No posts yet. Check back soon.</p>
      )
    }
  </div>
</PageLayout>
