---
import PageLayout from '@/layouts/PageLayout.astro';
import ResearchAreaCard from '@/components/academic/ResearchAreaCard.astro';
import { researchAreas } from '@/data/research';
---

<PageLayout
  title="Research"
  description="Research areas: automotive cybersecurity, IoT security, V2X trust management, risk management, malware analysis, and applied cryptography."
  pageTitle="Research"
  pageSubtitle="My work spans several interconnected areas of cybersecurity, with a particular focus on safety-critical and embedded environments."
>
  <div class="py-8">
    <!-- Table of contents -->
    <nav aria-label="Research areas" class="mb-12 p-5 bg-white border border-[#E5E7EB] rounded-xl max-w-2xl">
      <p class="text-xs font-semibold text-[#6B7280] uppercase tracking-wide mb-3">Areas</p>
      <ol class="space-y-1">
        {researchAreas.map((area, i) => (
          <li>
            <a
              href={`#${area.slug}`}
              class="text-sm text-[#1E3A8A] hover:underline"
            >
              {i + 1}. {area.title}
            </a>
          </li>
        ))}
      </ol>
    </nav>

    <!-- Research areas -->
    <div>
      {researchAreas.map((area) => (
        <ResearchAreaCard area={area} />
      ))}
    </div>
  </div>
</PageLayout>
